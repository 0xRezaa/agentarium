{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "#openharness/*": ["./packages/openharness/src/*"],
      "#openharness": ["./packages/openharness/src"],
      "#core/*": ["./packages/core/src/*"],
      "#core": ["./packages/core/src"],
      "#model-webllm/*": ["./packages/model-webllm/src/*"],
      "#model-webllm": ["./packages/model-webllm/src"],
      "#chat-assistant/web/*": ["./packages/chat-assistant/web/src/*"],
      "#chat-assistant/web": ["./packages/chat-assistant/web/src"],
      "#chat-assistant/server/*": ["./packages/chat-assistant/server/src/*"],
      "#chat-assistant/server": ["./packages/chat-assistant/server/src"]
    },
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true
  }
}

{
  "name": "agentarium",
  "description": "Browser-native demos for inspectable AI agent systems.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev -w @0xrezaa/openharness",
    "build": "npm run build -w @0xrezaa/openharness",
    "typecheck": "npm run typecheck -w @0xrezaa/openharness",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}

{
  "name": "agentarium",
  "description": "Browser-native demos for inspectable AI agent systems.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev -w @agentarium/open-harness",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "clean": "rimraf packages/*/dist"
  }
}

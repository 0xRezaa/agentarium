{
  "name": "@0xrezaa/chat-assistant",
  "version": "0.0.0",
  "private": false,
  "description": "Simple fullstack chat assistant demo, driven by webllm. Supports branching conversations.",
  "license": "MIT",
  "author": "Reza Banazadeh",
  "type": "module",
  "files": [
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:web": "cd web && vite build",
    "build:server": "tsc -p server/tsconfig.build.json",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres pgadmin",
    "db:up": "docker compose up -d",
    "dev": "concurrently -k -n web,server -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "cd web && vite",
    "dev:server": "tsx watch server/src/index.ts",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "preview:web": "cd web && vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run start:server",
    "start:server": "node server/dist/index.js",
    "typecheck": "tsc -p web/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "generate:api-types": "concurrently -k --success command-types -n server,types \"tsx server/src/index.ts\" \"wait-on http://localhost:3000/openapi.json && npm run generate:api-types:once\"",
    "generate:api-types:once": "openapi-typescript http://localhost:3000/openapi.json -o web/src/api/openapi-generated.ts",
    "db:codegen": "kysely-codegen --config-file .kysely-codegenrc.json",
    "db:codegen:check": "kysely-codegen --config-file .kysely-codegenrc.json --verify",
    "db:migrate": "tsx server/src/db/migrate.ts latest",
    "db:migrate:down": "tsx server/src/db/migrate.ts down"
  },
  "dependencies": {
    "@0xrezaa/core": "^0.0.0",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "kysely-codegen": "^0.20.0",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wait-on": "^9.0.3"
  }
}

{
  "name": "@0xrezaa/chat-assistant",
  "version": "0.0.0",
  "private": false,
  "description": "Simple fullstack chat assistant demo, driven by webllm. Supports branching conversations.",
  "license": "MIT",
  "author": "Reza Banazadeh",
  "type": "module",
  "files": [
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:web": "react-router build",
    "build:server": "tsc ./server",
    "dev": "npm run dev:web && npm run dev:server",
    "dev:web": "react-router dev",
    "dev:server": "tsx watch server/src/index.ts",
    "start": "npm run start:web && npm run start:server",
    "start:web": "react-router-serve ./web/build/server/index.js",
    "start:server": "node server/dist/index.js",
    "typecheck": "react-router typegen ./web && tsc"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "hono": "^4.12.23",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.16.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}

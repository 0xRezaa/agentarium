{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "#chat-assistant/*": ["./src/*"],
      "#chat-assistant": ["./src"]
    }
  },
  "include": ["src", "vite.config.ts"]
}

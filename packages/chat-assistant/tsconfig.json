{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*", "**/.server/**/*", "**/.client/**/*", "web/types/**/*"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vite/client"],
    "target": "ESNext",
    "module": "NodeNext",
    "jsx": "react-jsx",
    "rootDirs": [".", "web/types"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
